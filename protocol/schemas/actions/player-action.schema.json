{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "two-spies/player-action",
  "title": "PlayerAction",
  "description": "A move, attack, or end-turn action sent from a client to the server.",
  "type": "object",
  "required": ["type", "sessionId", "playerId"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["PLAYER_MOVE", "PLAYER_ATTACK", "PLAYER_END_TURN"]
    },
    "sessionId": { "type": "string", "minLength": 1 },
    "playerId":  { "type": "string", "minLength": 1 },
    "from": {
      "type": "object",
      "required": ["row", "col"],
      "properties": {
        "row": { "type": "integer", "minimum": 0, "maximum": 9 },
        "col": { "type": "integer", "minimum": 0, "maximum": 9 }
      }
    },
    "to": {
      "type": "object",
      "required": ["row", "col"],
      "properties": {
        "row": { "type": "integer", "minimum": 0, "maximum": 9 },
        "col": { "type": "integer", "minimum": 0, "maximum": 9 }
      }
    }
  }
}

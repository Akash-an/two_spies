# -----------------------------------------------
# Secrets / API Keys
# -----------------------------------------------
.env
.env.local
.env.*.local
letsencrypt/

# -----------------------------------------------
# Frontend (Node / Vite)
# -----------------------------------------------
stitch-frontend/node_modules/
stitch-frontend/dist/
stitch-frontend/.vite/
stitch-frontend/.env
stitch-frontend/.env.local
stitch-frontend/.env.*.local
stitch-frontend/vite.log

# Block compiled JS artifacts from being committed alongside TypeScript source.
# The tsconfig has noEmit:true so these should never appear in src/, but guard anyway.
stitch-frontend/src/**/*.js
stitch-frontend/vite.config.js
node_modules/

# -----------------------------------------------
# Backend (CMake / C++)
# -----------------------------------------------
build/
backend/build/
backend/build-test/
backend/.cache/
backend/server.log
*.o
*.a
*.so
*.dylib
*.pid
compile_commands.json

# -----------------------------------------------
# Agent Skills (Installed vs Custom)
# -----------------------------------------------
# Ignore installed skills (can be reinstalled from skills-lock.json)
.agents/skills/find-skills/
.agents/skills/phaser-gamedev/
.agents/skills/screenshot-to-code/
.agents/skills/resolve-conflicts/
.agents/skills/playwright-cli/
.agents/skills/design-md/
.agents/skills/react-components/
.agents/skills/stitch-design/

# Keep custom project skills (rebuild-and-restart, two-spies-gamedesign)
# These are NOT ignored and will be committed

# Keep skills-lock.json (tracks installed skills)
!skills-lock.json

# -----------------------------------------------
# Logs
# -----------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------
# OS / editor
# -----------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------
# Temporary / Test files
# -----------------------------------------------
*.tmp
*.temp
.cache/
